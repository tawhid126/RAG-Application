# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here

# Qdrant Vector Database Configuration
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=universal_knowledge

# Application Configuration
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# RAG Configuration
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K_RESULTS=5
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-4o-mini

# File Paths
MANUALS_DIR=./data/manuals
LOGS_DIR=./logs

# Optional: Database Connection Strings (for multi-source ingestion)
# POSTGRES_URL=postgresql://user:password@localhost:5432/dbname
# MONGODB_URL=mongodb://localhost:27017
# MYSQL_URL=mysql://user:password@localhost:3306/dbname

# Paths
MANUALS_DIR=/app/data/manuals
LOGS_DIR=/app/logs
